# .envrc — direnv configuration for pirogue-ai-triage
#
# This file is safe to commit — it contains no secrets.
# direnv + nix-direnv will:
#   1. Load the nix shell from laptop/shell.nix
#   2. Export ANTHROPIC_API_KEY from the sops-nix decrypted secret

# Load nix shell
use nix laptop/shell.nix

# Load API key from sops-nix decrypted secret
if [ -r /run/secrets/anthropic_api_key ]; then
  export ANTHROPIC_API_KEY="$(cat /run/secrets/anthropic_api_key)"
fi
