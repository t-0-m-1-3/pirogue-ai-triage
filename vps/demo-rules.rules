# =============================================================================
# PiRogue Conference Demo - Custom Suricata Rules
# Domain: your-demo-domain.com
# =============================================================================
# Deploy to: /var/lib/suricata/rules/demo-rules.rules  (NOT /etc/suricata/rules/)
# Add to suricata.yaml under rule-files:
#   - demo-rules.rules
# Restart: sudo systemctl restart suricata
# =============================================================================

# ---------------------------------------------------------------------------
# RULE 1: DNS C2 Domain (Primary Demo - most reliable, use on stage)
# ---------------------------------------------------------------------------
# Trigger: Open browser on phone → navigate to your-demo-domain.com

alert dns any any -> any any ( \
    msg:"PIROGUE-DEMO [HIGH] Known C2 Domain Contacted - APT Simulation"; \
    dns.query; content:"your-demo-domain.com"; nocase; \
    classtype:trojan-activity; \
    metadata:deployment demo, severity high, confidence high, \
             mitre_tactic command-and-control, mitre_technique T1071.004; \
    sid:9999901; rev:2; )

# ---------------------------------------------------------------------------
# RULE 2: Stalkerware subdomain
# ---------------------------------------------------------------------------
# Trigger: Navigate to tracker.your-demo-domain.com on the phone

alert dns any any -> any any ( \
    msg:"PIROGUE-DEMO [HIGH] Stalkerware Domain Resolution Detected"; \
    dns.query; content:"tracker.your-demo-domain.com"; nocase; \
    classtype:trojan-activity; \
    metadata:deployment demo, severity high, confidence high, \
             mitre_tactic collection, mitre_technique T1429; \
    sid:9999902; rev:2; )

# ---------------------------------------------------------------------------
# RULE 3: JA3 Fingerprint Match (COMMENTED OUT — requires setup)
# ---------------------------------------------------------------------------
# This rule ships disabled. To enable it:
#
#   1. Enable JA3 in suricata.yaml:
#        ja3-fingerprints: yes  (under app-layer > protocols > tls)
#
#   2. Enable TLS extended logging in your file-based eve-log types:
#        - tls:
#            extended: yes
#
#   3. Restart Suricata, browse to https://your-demo-domain.com from the phone
#
#   4. Grab the hash:
#        sudo jq -r 'select(.event_type=="tls") | .tls.ja3.hash' \
#          /var/log/suricata/eve.json | sort -u
#
#   5. Replace YOUR_JA3_HASH_HERE below with the actual hash
#
#   6. Uncomment the rule, restart Suricata
#
#   7. Test by hitting the VPS directly through WireGuard (bypasses Cloudflare):
#        curl --tlsv1.2 --tls-max 1.2 \
#             --ciphers ECDHE-ECDSA-AES128-GCM-SHA256 \
#             -k --resolve "your-demo-domain.com:443:10.8.0.1" \
#             https://your-demo-domain.com/beacon
#
#      Note: Use ECDHE-ECDSA (not RSA) if your Cloudflare origin cert is ECDSA.
#      Cloudflare's edge doesn't support forced ciphers, so hit the VPS directly.
#
# alert tls any any -> any any ( \
#     msg:"PIROGUE-DEMO [CRITICAL] TLS Client Fingerprint Matches Known Implant"; \
#     ja3.hash; content:"YOUR_JA3_HASH_HERE"; \
#     classtype:trojan-activity; \
#     metadata:deployment demo, severity critical, confidence medium, \
#              mitre_tactic command-and-control, mitre_technique T1573.002; \
#     sid:9999903; rev:2; )

# ---------------------------------------------------------------------------
# RULE 4: HTTP Beacon Pattern
# ---------------------------------------------------------------------------
# Trigger: curl -A "Mozilla/5.0 (compatible; BabyShark/2.0)" \
#               http://your-demo-domain.com/gate.php
#
# MUST be plain HTTP (port 80) — Suricata can't inspect User-Agent over HTTPS.
# Make sure nginx listens on port 80 on the WireGuard IP too (10.8.0.1:80).
# Also disable "Always Use HTTPS" in Cloudflare if triggering through CF.

alert http any any -> any any ( \
    msg:"PIROGUE-DEMO [CRITICAL] C2 Beacon Callback - Suspicious User-Agent"; \
    flow:to_server,established; \
    http.user_agent; content:"BabyShark"; \
    classtype:trojan-activity; \
    metadata:deployment demo, severity critical, confidence high, \
             mitre_tactic command-and-control, mitre_technique T1071.001; \
    sid:9999904; rev:2; )

# ---------------------------------------------------------------------------
# RULE 5: Data Exfiltration Simulation
# ---------------------------------------------------------------------------
# Trigger: dig TXT exfil-test.your-demo-domain.com
#      or: nslookup -type=TXT exfil-test.your-demo-domain.com

alert dns any any -> any any ( \
    msg:"PIROGUE-DEMO [HIGH] DNS TXT Query - Possible Data Exfiltration Channel"; \
    dns.query; content:"exfil-test"; \
    dns.query; content:"your-demo-domain.com"; \
    classtype:bad-unknown; \
    metadata:deployment demo, severity high, confidence medium, \
             mitre_tactic exfiltration, mitre_technique T1048.003; \
    sid:9999905; rev:2; )


# =============================================================================
# PRE-TALK CHECKLIST
# =============================================================================
# [ ] your-demo-domain.com resolves correctly (dig your-demo-domain.com)
# [ ] nginx serving demo site: curl https://your-demo-domain.com/health
# [ ] Demo rules deployed to /var/lib/suricata/rules/ (NOT /etc/suricata/rules/)
# [ ] Suricata config updated per demo-site/SURICATA_CONFIG.md
# [ ] Suricata running: sudo systemctl status suricata
# [ ] eve.json getting data: sudo tail -3 /var/log/suricata/eve.json
# [ ] Triage daemon running: sudo systemctl status pirogue-triage
# [ ] signal-cli encryption synced: signal-cli -a +1YOUR receive
# [ ] Anthropic API credits loaded
# [ ] Each trigger fires an alert in eve.json
# [ ] Signal notifications arrive on phone
# [ ] Target: trigger → notification in under 15 seconds
# [ ] Backup demo video recorded
# =============================================================================
